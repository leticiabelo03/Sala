@model IEnumerable<Sala.ViewModel.UsuarioListViewModel>

@{
    ViewData["Title"] = "Chamados";

    if (User.IsInRole("Admin"))
    {
        Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    }
    else if (User.IsInRole("Tecnico"))
    {
        Layout = "~/Views/Shared/_LayoutTecnico.cshtml";
    }
    else if (User.IsInRole("Financeiro"))
    {
        Layout = "~/Views/Shared/_LayoutFinanceiro.cshtml";
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Lista de Usuários</h2>
    <a asp-action="Criar" class="btn btn-primary">Novo Usuário</a>
</div>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Email</th>
            <th>Perfil</th>
            <th class="text-end">Ações</th>
        </tr>
    </thead>
    <tbody>

        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center">Nenhum usuário cadastrado</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                var corPerfil = item.PerfilUsuario switch
                {
                    Sala.Model.PerfilUsuarioEnum.Admin => "badge bg-danger",
                    Sala.Model.PerfilUsuarioEnum.Tecnico => "badge bg-warning text-dark",
                    Sala.Model.PerfilUsuarioEnum.Financeiro => "badge bg-success",
                    _ => "badge bg-secondary"
                };

                var perfilTexto = item.PerfilUsuario switch
                {
                    Sala.Model.PerfilUsuarioEnum.Admin => "Admin",
                    Sala.Model.PerfilUsuarioEnum.Tecnico => "Técnico",
                    Sala.Model.PerfilUsuarioEnum.Financeiro => "Financeiro",
                    _ => item.PerfilUsuario.ToString()
                };

                <tr>
                    <td>@item.Id</td>
                    <td>@item.Nome</td>
                    <td>@item.Email</td>
                    <td>
                        <span class="@corPerfil">@perfilTexto</span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Ver</a>
                        <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Deletar" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Excluir</a>
                    </td>
                </tr>
            }
        }

    </tbody>
</table>