@model Sala.ViewModel.UsuarioCreateViewModel

@{
    ViewData["Title"] = "Chamados";

    if (User.IsInRole("Admin"))
    {
        Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    }
    else if (User.IsInRole("Tecnico"))
    {
        Layout = "~/Views/Shared/_LayoutTecnico.cshtml";
    }
    else if (User.IsInRole("Financeiro"))
    {
        Layout = "~/Views/Shared/_LayoutFinanceiro.cshtml";
    }
}

<h2>Criar Usuário</h2>

<form asp-action="Criar" method="post">
    <div class="form-group">
        <label>Nome</label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="form-group">
        <label>Senha</label>
        <input asp-for="Senha" type="password" class="form-control" />
    </div>
    <div class="form-group">
        <label>Perfil</label>
        <select asp-for="PerfilUsuario" asp-items="Html.GetEnumSelectList<Sala.Model.PerfilUsuarioEnum>()" class="form-control">
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Salvar</button>
</form>