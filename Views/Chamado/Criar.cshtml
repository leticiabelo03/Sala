@model Sala.ViewModel.ChamadoCreateViewModel

@{
    ViewData["Title"] = "Novo Chamado";

    if (User.IsInRole("Admin"))
    {
        Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    }
    else if (User.IsInRole("Tecnico"))
    {
        Layout = "~/Views/Shared/_LayoutTecnico.cshtml";
    }
    else if (User.IsInRole("Financeiro"))
    {
        Layout = "~/Views/Shared/_LayoutFinanceiro.cshtml";
    }
}

<div class="container mt-4">
    <h4>Novo Chamado</h4>
    <hr />

    <form asp-action="Criar" method="post">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Titulo" class="form-label">Título</label>
                <input asp-for="Titulo" class="form-control" placeholder="Resumo do problema" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="ClienteId" class="form-label">Cliente</label>
                <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.Clientes">
                    <option value="">Selecione um cliente...</option>
                </select>
                <span asp-validation-for="ClienteId" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="CategoriaId" class="form-label">Categoria</label>
                <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.Categorias">
                    <option value="">Selecione uma categoria...</option>
                </select>
                <span asp-validation-for="CategoriaId" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Status" class="form-label">Status Inicial</label>
                <select asp-for="Status" class="form-select"
                        asp-items="Html.GetEnumSelectList<Sala.Model.StatusChamadoEnum>()">
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="col-12 mb-3">
                <label asp-for="Descricao" class="form-label">Descrição Detalhada</label>
                <textarea asp-for="Descricao" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Descricao" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="PrioridadeChamado" class="form-label">Prioridade</label>
                <select asp-for="PrioridadeChamado" class="form-select"
                        asp-items="Html.GetEnumSelectList<Sala.Model.PrioridadeChamadoEnum>()">
                </select>
                <span asp-validation-for="PrioridadeChamado" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-success">Salvar Chamado</button>
            <a asp-action="Index" class="btn btn-secondary">Voltar</a>
        </div>
    </form>
</div>