<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            :root {
                --green-dark: #014c0e;
                --green-mid: #008a2c;
                --bg: #e9ecef;
            }

            body {
                background: var(--bg);
                font-family: 'Segoe UI';
                margin: 0;
            }

            .sidebar {
                width: 260px;
                height: 100vh;
                position: fixed;
                background: linear-gradient(180deg, var(--green-dark), var(--green-mid));
                padding: 20px;
                color: white;
            }

            .sidebar .nav-link {
                color: white;
                background: rgba(255, 255, 255, .08);
                padding: 12px;
                margin-bottom: 10px;
                border-radius: 12px;
                text-decoration: none;
                display: block;
            }

            .sidebar .nav-link:hover {
                background: white;
                color: var(--green-dark);
            }

            .main {
                margin-left: 260px;
                padding: 25px;
            }

            .top {
                background: white;
                padding: 15px 25px;
                border-radius: 15px;
                margin-bottom: 25px;
                display: flex;
                justify-content: space-between;
            }

            .card-sala {
                background: white;
                padding: 20px;
                border-radius: 20px;
                box-shadow: 0 6px 18px rgba(0, 0, 0, .06);
            }
    </style>
</head>

<body>

    <div class="sidebar d-flex flex-column">

        <h4 class="text-center">💰 SALA</h4>
        <small class="text-center mb-4">Financeiro</small>

        <a asp-controller="Financeiro" asp-action="Dashboard" class="nav-link">
            Dashboard
        </a>

        <a asp-controller="Financeiro" asp-action="Faturas" class="nav-link">
            Faturas Emitidas
        </a>

        <div class="mt-auto">
            <a asp-controller="Auth" asp-action="Logout" class="btn btn-light w-100">
                Sair
            </a>
        </div>

    </div>

    <div class="main">

        <div class="top">
            <strong>@ViewData["Title"]</strong>
            <span>@User.Identity?.Name</span>
        </div>

        @RenderBody()

    </div>

</body>

</html>