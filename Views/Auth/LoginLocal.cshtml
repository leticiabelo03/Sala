@model Sala.ViewModel.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <title>Login SALA</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@800&display=swap" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #003366 0%, #0165c8 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
        }

        .login-box {
            width: 360px;
            padding: 40px;
            border-radius: 20px;
            text-align: center;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.2);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }

        .titulo-sala {
            font-family: 'Montserrat', sans-serif;
            color: #fff;
            letter-spacing: 4px;
            margin-bottom: 25px;
        }

        .form-control {
            border-radius: 12px;
            padding: 10px;
        }

        .btn-login {
            border-radius: 12px;
            font-weight: bold;
        }
    </style>
</head>

<body>

<div class="login-box">

    <h1 class="titulo-sala">SALA</h1>

    <form asp-action="LoginLocal" method="post">

        <input asp-for="Email" class="form-control mb-2" placeholder="Digite seu email" />
        <span asp-validation-for="Email" class="text-warning small"></span>

        <input asp-for="Senha" type="password" class="form-control mb-3" placeholder="Digite sua senha" />
        <span asp-validation-for="Senha" class="text-warning small"></span>

        <button type="submit" class="btn btn-dark w-100 btn-login">
            Entrar no Sistema
        </button>

    </form>

    <div class="mt-3">
        <a href="#" class="text-white-50 small text-decoration-none">
            Esqueceu sua senha?
        </a>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <p class="text-warning mt-3">Acesso negado!</p>
    }

</div>

</body>
</html>